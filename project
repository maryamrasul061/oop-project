// buttons with hover colors

class RoundedButton extends JButton 
{
    private Color bgColor;
      private Color hoverColor;
    private boolean hovered=false;
       private int arc;

    public RoundedButton(String text, Color bgColor, int arc) {
        super(text);
        this.bgColor=bgColor;
        this.hoverColor = bgColor.darker();
         this.arc = arc;
        setOpaque(false);
          setContentAreaFilled(false);
        setBorderPainted(false);
          setFocusPainted(false);
        setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
         setForeground(Color.WHITE);
        setFont(new Font("Segoe UI", Font.BOLD, 14));
          setBorder(BorderFactory.createEmptyBorder(10, 28, 10, 28));

        addMouseListener(new MouseAdapter() {
            public void mouseEntered(MouseEvent e) { hovered=true; repaint(); }
             public void mouseExited(MouseEvent e) { hovered=false; repaint(); }
        });
    }

    @Override
    protected void paintComponent(Graphics g) {
        Graphics2D g2 = (Graphics2D) g.create();
         g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
        g2.setColor(hovered?hoverColor:bgColor);
          g2.fillRoundRect(0, 0, getWidth(), getHeight(), arc, arc);
        g2.dispose();
        super.paintComponent(g);
    }
}


// handles all the logic and text file saving

class ScheduleManager implements SchedulerOperations {
    private static final int FIRST_ROOM= 201;
       private static final int MAX_ROOMS=10;
    private static final String SAVE_FILE = "schedules.txt"; 

       private ArrayList<Schedule> schedules; 

    public ScheduleManager() {
        schedules = new ArrayList<>();
          loadFromFile();
    }

    public String checkClash(Schedule n) {
        for(Schedule s : schedules) {
            
            if(!s.getDay().equals(n.getDay()) || !s.getTime().equals(n.getTime())) continue;
            
            if(s.getTeacher().getName().equalsIgnoreCase(n.getTeacher().getName())) {
                return "Teacher Clash!\n" + n.getTeacher().getName() + " already has a class on " + n.getDay() + " at " + n.getTime();
            }
            if(s.getDepartment().equals(n.getDepartment()) && s.getSection().equals(n.getSection())) {
                return "Section Clash!\n" + n.getDepartment() + " Section " + n.getSection() + " already has a class at this time slot.";
            }
            
            if(s.getRoom().getRoomNo()==n.getRoom().getRoomNo()) {
                return "Room Clash!\nRoom " + n.getRoom().getRoomNo() + " is already booked on " + n.getDay() + " at " + n.getTime();
            }
        }
        return null; 
    }

    public int allocateRoom(String day, String time) {
        for(int room=FIRST_ROOM; room<FIRST_ROOM+MAX_ROOMS; room++) {
            boolean used=false;
            for(Schedule s : schedules) {
                if(s.getDay().equals(day) && s.getTime().equals(time) && s.getRoom().getRoomNo()==room) {
                    used = true;
                    break;
                }
            }
            if(!used) return room;
        }
        return -1; 
    }

    public boolean addSchedule(Schedule s) {
        schedules.add(s);
          saveToFile();
        return true;
    }

    public void deleteSchedule(int index) {
        if(index>=0 && index<schedules.size()) {
            schedules.remove(index);
             saveToFile();
        }
    }

    public ArrayList<Schedule> getSchedules() { return schedules; }

    public void saveToFile() {
        try(PrintWriter writer=new PrintWriter(new FileWriter(SAVE_FILE))) {
            for(Schedule s : schedules) {
                writer.println(s.getDepartment()+","+s.getSection()+","+s.getDay()+","+ 
                               s.getTime()+","+s.getTeacher().getName()+","+ 
                               s.getTeacher().getSubject()+","+s.getRoom().getRoomNo());
            }
        }catch(IOException ex) {
            System.err.println("Could not save data: " + ex.getMessage());
        }
    }

    public void loadFromFile() {
        File file = new File(SAVE_FILE);
        if(!file.exists()) return;
        try(BufferedReader reader=new BufferedReader(new FileReader(file))) {
            String line;
            while((line=reader.readLine())!=null) {
                String[] data = line.split(","); 
                if(data.length==7) {
                    Teacher t=new Teacher(data[4], data[5]);
                    Room r=new Room(Integer.parseInt(data[6]));
                    schedules.add(new Schedule(data[0], data[1], data[2], data[3], t, r));
                }
            }
        }catch(IOException | NumberFormatException ex) {
            System.err.println("Error reading data: " + ex.getMessage());
        }
    }
}


// table window for departments

class DisplayWindow extends JFrame 
{
    public DisplayWindow(ScheduleManager manager, String department, String sectionFilter) {
        String titleText = department + (sectionFilter.equals("ALL") ? " - All Sections" : " - Section " + sectionFilter);
        setTitle(titleText + " Schedule");
          setSize(1024, 560);
        setLocationRelativeTo(null);
          setLayout(new BorderLayout());
        getContentPane().setBackground(new Color(240, 243, 250));

        JPanel header = new JPanel(new BorderLayout());
         header.setBackground(new Color(16, 34, 80)); 
        header.setBorder(BorderFactory.createEmptyBorder(14,24,14,24));
          JLabel title = new JLabel(titleText);
        title.setFont(new Font("Segoe UI", Font.BOLD, 20));
         title.setForeground(Color.WHITE);
        header.add(title, BorderLayout.WEST);
          add(header, BorderLayout.NORTH);

        ArrayList<Schedule> schedules = manager.getSchedules();
        String[] columns = { "Dept", "Section", "Teacher", "Subject", "Room", "Day", "Time" };
          ArrayList<Integer> indices = new ArrayList<>();
        ArrayList<String[]> rows = new ArrayList<>();

        for(int i=0; i<schedules.size(); i++) {
            Schedule s = schedules.get(i);
            if(s.getDepartment().equals(department)) {
                if(sectionFilter.equals("ALL") || s.getSection().equals(sectionFilter)) {
                    rows.add(new String[]{
                        s.getDepartment(), s.getSection(), s.getTeacher().getName(),
                        s.getTeacher().getSubject(), String.valueOf(s.getRoom().getRoomNo()),
                        s.getDay(), s.getTime()
                    });
                    indices.add(i); 
                }
            }
        }

        String[][] data = rows.toArray(new String[0][]);

        JTable table = new JTable(data, columns) {
            public boolean isCellEditable(int r, int c) { return false; }
            public Component prepareRenderer(javax.swing.table.TableCellRenderer r, int row, int col) {
                Component c = super.prepareRenderer(r, row, col);
                if(!isRowSelected(row)) {
                    c.setBackground(row%2==0 ? Color.WHITE : new Color(248, 250, 255));
                }
                return c;
            }
        };
        table.setRowHeight(36);
          table.setFont(new Font("Segoe UI", Font.PLAIN, 14));
        table.getTableHeader().setFont(new Font("Segoe UI", Font.BOLD, 14));
         table.getTableHeader().setBackground(Color.WHITE); 
        table.getTableHeader().setForeground(new Color(16, 34, 80));
         table.getTableHeader().setBorder(BorderFactory.createMatteBorder(0,0,2,0, new Color(210,218,235)));
        table.getTableHeader().setPreferredSize(new Dimension(0, 40));
          table.setSelectionBackground(new Color(200, 220, 255));
        table.setGridColor(new Color(230, 234, 242));
         table.setShowVerticalLines(false);
        table.setIntercellSpacing(new Dimension(0, 1));
          table.setSelectionMode(ListSelectionModel.SINGLE_SELECTION);

        JScrollPane pane=new JScrollPane(table);
        pane.setBorder(BorderFactory.createEmptyBorder(16,20,4,20));
         pane.setOpaque(false);
        pane.getViewport().setOpaque(false);

        RoundedButton deleteButton = new RoundedButton("Delete Selected", new Color(220, 53, 69), 20);
        deleteButton.addActionListener(ev -> {
            int selectedRow = table.getSelectedRow();
            if(selectedRow==-1) {
                JOptionPane.showMessageDialog(this, "Please select a row to delete.");
                return;
            }
            int confirm = JOptionPane.showConfirmDialog(this, "Delete this schedule entry?", "Confirm Delete", JOptionPane.YES_NO_OPTION);
            if(confirm == JOptionPane.YES_OPTION) {
                manager.deleteSchedule(indices.get(selectedRow));
                JOptionPane.showMessageDialog(this, "Schedule deleted and saved.");
                dispose();
            }
        });

        JPanel south=new JPanel(new FlowLayout(FlowLayout.RIGHT, 20, 12));
         south.setBackground(new Color(240, 243, 250));
        south.add(deleteButton);

        add(pane, BorderLayout.CENTER);
         add(south, BorderLayout.SOUTH);
        setVisible(true);
    }
}


